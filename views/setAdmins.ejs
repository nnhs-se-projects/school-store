<%- include('include/_header') %>

<link rel="stylesheet" href="/css/setVolunteers.css" />

<main>
  <div class="wrapper">
    <h1>Set Admins</h1>
    <p class="page-copy">
      Enter one admin email per line. Changes are saved and will apply to
      future sign-ins immediately.
    </p>

    <% if (query.saved) { %>
    <p class="status-message">Admin emails saved.</p>
    <% } %>

    <form action="/setAdmins" method="POST" class="volunteer-form">
      <label for="adminEmails">Admin Emails</label>
      <textarea
        id="adminEmails"
        name="adminEmails"
        rows="12"
        spellcheck="false"
      ><%= adminEmails.join('\n') %></textarea>
      <button type="submit">Save Admins</button>
    </form>
  </div>
</main>

<%- include('include/_footer') %>
