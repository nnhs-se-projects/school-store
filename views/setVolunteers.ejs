<%- include('include/_header') %>

<link rel="stylesheet" href="/css/setVolunteers.css" />

<main>
  <div class="wrapper">
    <h1>Set Volunteers</h1>
    <p class="page-copy">
      Enter one volunteer email per line. Changes are saved to the database and
      will apply to future sign-ins immediately.
    </p>

    <% if (query.saved) { %>
    <p class="status-message">Volunteer emails saved.</p>
    <% } %>

    <form action="/setVolunteers" method="POST" class="volunteer-form">
      <label for="volunteerEmails">Volunteer Emails</label>
      <textarea
        id="volunteerEmails"
        name="volunteerEmails"
        rows="12"
        spellcheck="false"
      ><%= volunteerEmails.join('\n') %></textarea>
      <button type="submit">Save Volunteers</button>
    </form>
  </div>
</main>

<%- include('include/_footer') %>