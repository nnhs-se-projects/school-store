<!-- include header -->
<%- include('include/_header') %>
<!-- /include header -->

<style>
  textarea {
    resize: vertical;
    min-height: 15em;

    font-family: Verdana, sans-serif;
  }
</style>

<!-- Main Site -->

<main>
  <div class="wrapper">
    <h1>Edit Email Text</h1>

    <h2>Order Confirmation</h2>
    <p>To School Store Email:</p>
    <textarea id="confirm-store-text"><%= confirmStoreText %></textarea>

    <p>To Student Email:</p>
    <textarea id="confirm-student-text"><%= confirmStudentText %></textarea>

    <h2>Order Cancellation</h2>
    <textarea id="cancel-student-text"><%= cancelStudentText %></textarea>

    <br>
    <button id="save-btn">Save All</button>
  </div>
</main>

<!-- /Main Site -->

<script src="/js/editEmail.js"></script>

<!-- include footer -->
<%- include('include/_footer') %>
<!-- /include footer -->
