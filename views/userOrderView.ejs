<!-- include header -->
<%- include('include/_header') %>
<!-- /include header -->

<link rel="stylesheet" href="/css/userOrderView.css" />

<!-- Main Site -->

<main>
  <div class="wrapper">
    <h1>Your Orders</h1>

    <div class="overflow-wrapper">
      <% for (const order of userOrders) { %>
      <div class="order-block">
        <h2>Date: <%= ((new Date(order.date)).toUTCString()).split(" 00:00:00 GMT")[0] %></h2>
      <!-- FIXME: Need to add pickup time -->
        <h2>Total: $<%= order.totalPrice %></h2>
        <table class="order-items">
          <tr>
            <th colspan="3" class="main-heading">Items</th>
          </tr>
          <tr>
            <th>Name</th>
            <th>Size</th>
            <th>Quantity</th>
          </tr>
        <% for (const item of order.items) { %>
          <tr>
            <td><%= item.name %></td>
            <td><%= item.size %></td>
            <td><%= item.quantity %></td>
          </tr>
        <% } %>
        </table>
        <p>Order #<%= order.orderNumber %></p>
      </div>
      <% } %>
    </div>
  </div>
</main>

<!-- /Main Site -->

<!-- include footer -->
<%- include('include/_footer') %>
<!-- /include footer -->
